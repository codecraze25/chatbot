# Copy to .env in the project root for docker compose variable substitution
# cp .env.example .env

# --- OpenAI (default) ---
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-key-here

# --- Local Ollama on your machine (API runs in Docker) ---
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Ollama in Docker (use: docker compose --profile ollama up) ---
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2
# OLLAMA_BASE_URL=http://ollama:11434

SYSTEM_PROMPT=You are a helpful assistant.
MAX_MESSAGE_LENGTH=8000
MAX_CONTEXT_MESSAGES=50
RATE_LIMIT_PER_MINUTE=30
