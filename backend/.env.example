# Database
DATABASE_URL=sqlite:///./chatbot.db

# CORS (comma-separated origins — set CORS_ORIGINS as JSON array in .env)
# Example: CORS_ORIGINS=["http://localhost:5173"]

# AI
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-key-here
SYSTEM_PROMPT=You are a helpful assistant.

# Ollama (when AI_PROVIDER=ollama)
# Local dev:  http://localhost:11434
# Docker API + host Ollama: http://host.docker.internal:11434
# Docker Compose ollama service: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# Limits
MAX_MESSAGE_LENGTH=8000
MAX_CONTEXT_MESSAGES=50
RATE_LIMIT_PER_MINUTE=30
